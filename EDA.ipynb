## MODELOS ## - mudei esta parte 

# =========================
# PREPARAÇÃO DOS DADOS
# =========================

from sklearn.model_selection import train_test_split

# features (X) e target (y)
X = ortho.drop("mudanca_CPAK", axis=1)
y = ortho["mudanca_CPAK"]

X_train,X_test, y_train, y_test = train_test_split(X,y,test_size=0.30,random_state=42, stratify=y)

print("Distribuição da Target (CPAK) - Treino")
print("N.observações Treino", len(X_train))
print(y_train.value_counts(normalize=True))

print("Distribuição da Target (CPAK) - Teste")
print("N.observações Teste", len(X_test))
print(y_test.value_counts(normalize=True))

# Aplicar os modelos
# Árvore de decisão

from sklearn import tree

clf_DT = tree.DecisionTreeClassifier(random_state=42)
clf_DT = clf_DT.fit(X_train, y_train)

y_pred_DT = clf_DT.predict(X_test)
y_pred_DT

# Confusion Matrix

from sklearn.metrics import confusion_matrix

confusion_matrix = confusion_matrix(y_test, y_pred_DT)
print(confusion_matrix)


import matplotlib.pyplot as plt
import seaborn as sns

sns.heatmap(confusion_matrix, annot=True, fmt='d',cmap='crest')
plt.xlabel("Classe Prevista")
plt.ylabel("Classe Real")

plt.title("Matrix de confusão - Árvore de decisão")
plt.show()


from sklearn.metrics import classification_report

print(classification_report(y_test, y_pred_DT))

#Area Under the Curve (AUC)

from sklearn.metrics import roc_auc_score

auc = roc_auc_score(y_test, y_pred_DT)
print("AUC:", auc)


# Cross Validation: K-fold

from sklearn.model_selection import cross_val_predict

pred = cross_val_predict(clf_DT, X, y)

print(classification_report(y, pred, digits=4))





