   "outputs": [],
   "source": [
    "# conversão do tipo de \"grupo_pre\" para int64\n",
    "ortho['Grupo_pre'] = ortho['Grupo_pre'].astype('int64')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 73,
   "id": "6ce061b3",
   "metadata": {},
   "outputs": [],
   "source": [
    "# substituição da codificação da variavel 'Sexo' por outros valores numéricos para não induzir o modelo em erro hierárquico, \n",
    "# onde o valor 2 (masculino) seria considerado maior que o valor 1 (feminino), o que não é o caso. \n",
    "# original 1: feminino, 2: masculino\n",
    "# nova codificação 0: feminino, 1: masculino\n",
    "\n",
    "ortho.replace({'Sexo': {1: 0, 2: 1}}, inplace = True)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 74,
   "id": "496df0e1",
   "metadata": {},
   "outputs": [],
   "source": [
    "# gerar a variavel de interesse \"mudanca_CPAK\" que indica se houve mudança no grupo de classificação entre o pré e o pós-operatório.\n",
