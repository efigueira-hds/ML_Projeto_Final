                                     "\n",
                                     "# =========================\n",
                                     "# PREPARA脙鈥∶兤扥 DOS DADOS\n",
                                     "# =========================\n",
                                     "\n",
                                     "from sklearn.model_selection import train_test_split\n",
                                     "from sklearn.impute import SimpleImputer\n",
                                     "import pandas as pd\n",
                                     "\n",
                                     "# 1. Definir X e y\n",
                                     "X = ortho.drop(\"mudanca_CPAK\", axis=1)\n",
                                     "y = ortho[\"mudanca_CPAK\"]\n",
                                     "\n",
                                     "# 2. Criar imputer\n",
                                     "imputer = SimpleImputer(strategy=\u0027median\u0027)\n",
                                     "\n",
                                     "# 3. Fit + transform\n",
                                     "X_imputed = imputer.fit_transform(X)\n",
                                     "\n",
                                     "# 4. Converter para DataFrame\n",
                                     "import pandas as pd\n",
                                     "X_imputed = pd.DataFrame(X_imputed, columns=X.columns)\n",
                                     "\n",
                                     "# 5. Verificar NaN\n",
                                     "X_imputed.isna().sum().sum()\n",
                                     "\n",
                                     "X_train,X_test, y_train, y_test = train_test_split(X,y,test_size=0.30,random_state=42, stratify=y)\n",
                                     "\n",
                                     "print(\"Distribui脙搂脙拢o da Target (CPAK) - Treino\")\n",
                                     "print(\"N.observa脙搂脙碌es Treino\", len(X_train))\n",
                                     "print(y_train.value_counts(normalize=True))\n",
                                     "\n",
                                     "print(\"Distribui脙搂脙拢o da Target (CPAK) - Teste\")\n",
                                     "print(\"N.observa脙搂脙碌es Teste\", len(X_test))\n",
                                     "print(y_test.value_counts(normalize=True))\n",
                                     "\n",
                                     "# Aplicar os modelos\n",
                                     "# 脙聛rvore de decis脙拢o\n",
                                     "\n",
                                     "from sklearn import tree\n",
                                     "\n",
                                     "clf_DT = tree.DecisionTreeClassifier(random_state=42)\n",
                                     "clf_DT = clf_DT.fit(X_train, y_train)\n",
                                     "\n",
                                     "y_pred_DT = clf_DT.predict(X_test)\n",
                                     "y_pred_DT\n",
                                     "\n",
                                     "# Confusion Matrix\n",
                                     "\n",
                                     "from sklearn.metrics import confusion_matrix\n",
                                     "\n",
                                     "confusion_matrix = confusion_matrix(y_test, y_pred_DT)\n",
                                     "print(confusion_matrix)\n",
                                     "\n",
                                     "\n",
                                     "import matplotlib.pyplot as plt\n",
                                     "import seaborn as sns\n",
                                     "\n",
                                     "sns.heatmap(confusion_matrix, annot=True, fmt=\u0027d\u0027,cmap=\u0027crest\u0027)\n",
                                     "plt.xlabel(\"Classe Prevista\")\n",
                                     "plt.ylabel(\"Classe Real\")\n",
                                     "\n",
                                     "plt.title(\"Matrix de confus脙拢o - 脙聛rvore de decis脙拢o\")\n",
                                     "plt.show()\n",
                                     "\n",
                                     "\n",
                                     "from sklearn.metrics import classification_report\n",
                                     "\n",
                                     "print(classification_report(y_test, y_pred_DT))\n",
                                     "\n",
                                     "#Area Under the Curve (AUC)\n",
                                     "\n",
                                     "from sklearn.metrics import roc_auc_score\n",
                                     "\n",
                                     "auc = roc_auc_score(y_test, y_pred_DT)\n",
                                     "print(\"AUC:\", auc)\n",
                                     "\n",
                                     "\n",
                                     "# Cross Validation: K-fold\n",
                                     "\n",
                                     "from sklearn.model_selection import cross_val_predict\n",
                                     "\n",
                                     "pred = cross_val_predict(clf_DT, X_imputed, y)\n",
                                     "\n",
                                     "print(classification_report(y, pred, digits=4))\n",
                                     "\n",
                                     "\n",
                                     "\n",
                                     "### Regress脙拢o logistica\n",
                                     "\n",
                                     "from sklearn.linear_model import LogisticRegression\n",
